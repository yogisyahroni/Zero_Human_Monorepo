{
  "name": "@zh/hr",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config web/vite.config.ts",
    "dev": "concurrently -n api,web \"tsx watch src/server.ts\" \"vite --config web/vite.config.ts --host 0.0.0.0\"",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "@zh/sdk": "workspace:*",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.1.5",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3"
  }
}
