{
  "name": "zero-human-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous AI company operating system monorepo.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel dev",
    "dev:router": "pnpm --filter @zh/router dev",
    "dev:brain": "pnpm --filter @zh/brain dev",
    "dev:hr": "pnpm --filter @zh/hr dev",
    "upstream:status": "powershell -ExecutionPolicy Bypass -File scripts/upstream-status.ps1",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
