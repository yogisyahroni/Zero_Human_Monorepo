{
  "name": "zero-human-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous AI company operating system monorepo.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel dev",
    "dev:router": "pnpm --filter @zh/router dev",
    "dev:brain": "pnpm --filter @zh/brain dev",
    "dev:hr": "pnpm --filter @zh/hr dev",
    "stack:start": "powershell -ExecutionPolicy Bypass -File scripts/start-zero-human.ps1",
    "stack:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-zero-human.ps1",
    "stack:status": "powershell -ExecutionPolicy Bypass -File scripts/status-zero-human.ps1",
    "stack:logs": "powershell -ExecutionPolicy Bypass -File scripts/logs-zero-human.ps1",
    "skills:generate": "node scripts/generate-skill-registry.mjs",
    "upstream:status": "powershell -ExecutionPolicy Bypass -File scripts/upstream-status.ps1",
    "upstream:sync:router": "powershell -ExecutionPolicy Bypass -File scripts/sync-upstream.ps1 router",
    "router:update": "powershell -ExecutionPolicy Bypass -File scripts/sync-upstream.ps1 router; docker compose -p zero-human up -d --build 9router zh-router-adapter zh-brain-adapter zero-human",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
