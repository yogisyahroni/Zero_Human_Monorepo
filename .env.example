ZH_CONFIG_PATH=./config/zero-human.yaml
REDIS_URL=redis://localhost:6379

# AI provider keys are owned by 9Router. Prefer setting them in the 9Router UI
# at http://localhost:20128; these env values are only bootstrap/fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GLM_API_KEY=

# Internal OpenAI-compatible token used by Hermes when it calls 9Router.
# Do not put a real provider key here.
ZH_ROUTER_COMPAT_API_KEY=sk_9router

# Optional Codex executor model override. Leave empty to use the Codex default.
CODEX_MODEL=

DISCORD_WEBHOOK_URL=
