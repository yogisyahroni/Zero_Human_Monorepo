ZH_CONFIG_PATH=./config/zero-human.yaml
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -hex 32
# PowerShell alternative:
# [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).ToLower()
BETTER_AUTH_SECRET=

# 9Router gateway token.
# If 9Router > Endpoint > "Require API key" is enabled, create a key in the
# 9Router UI and paste it here. Hermes, Paperclip, and Codex use this token
# when calling 9Router through http://9router:20128/v1 inside Docker.
# Use the exact value from 9Router UI. Do not commit a real key.
ZH_ROUTER_COMPAT_API_KEY=<paste-9router-api-key-from-ui>

# Optional local/host aliases for tools that run outside Docker.
# Keep these pointed at 9Router, not at a direct provider, so routing stays
# centralized through 9Router combos.
CODEX_API_KEY=<same-as-ZH_ROUTER_COMPAT_API_KEY-for-host-tools>
OPENAI_BASE_URL=http://localhost:20128/v1
CODEX_OPENAI_BASE_URL=http://localhost:20128/v1
CODEX_MODEL=combotest

# AI provider keys are owned by 9Router. Prefer setting them in the 9Router UI
# at http://localhost:20128; these env values are only bootstrap/fallback for 9Router.
# Fill at least one provider key or configure it directly in the 9Router UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GLM_API_KEY=

DISCORD_WEBHOOK_URL=
